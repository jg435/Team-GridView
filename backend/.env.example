# Required for the LIVE agent path. Without it, the orchestrator
# transparently falls back to the deterministic canned arc.
OPENROUTER_API_KEY=sk-or-v1-...

# Optional. Defaults to anthropic/claude-sonnet-4.5 (one of OpenRouter's
# Claude routings). Pick any chat model that supports function calling:
#   anthropic/claude-sonnet-4.5
#   anthropic/claude-3.5-sonnet
#   openai/gpt-4o
#   openai/gpt-4o-mini
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Optional. Set to "replay" to force the canned arc even if a key is present.
# DEMO_MODE=replay

# Optional. EIA v2 API key for live ISO-NE data mode. Free at:
#   https://www.eia.gov/opendata/register.php
# When set, the dashboard's 'Live' toggle pulls real-time hourly ISO-NE demand
# from EIA-930. Without it, the dashboard runs against the bundled Jun 2024 replay.
# EIA_API_KEY=your_eia_key_here
