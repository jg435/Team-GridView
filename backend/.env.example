# Required for the LIVE Claude-driven negotiation path. Without it, the
# orchestrator transparently falls back to the deterministic canned arc.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Defaults to claude-sonnet-4-6.
# GRIDPARLEY_MODEL=claude-sonnet-4-6

# Optional. Set to "replay" to force the canned arc even if a key is present.
# DEMO_MODE=replay
